{
  "name": "what-ive-done",
  "version": "0.1.0",
  "description": "Local workflow pattern analyzer CLI",
  "type": "module",
  "bin": {
    "wid": "./dist/cli.js",
    "what-ive-done": "./dist/cli.js"
  },
  "scripts": {
    "build:web": "node --import tsx src/web/build.ts",
    "build": "node --import tsx src/web/build.ts && tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "dev:web": "node --import tsx src/web/build.ts --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
